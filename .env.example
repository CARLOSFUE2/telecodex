# Copia este archivo a .env y completa los valores
TELEGRAM_TOKEN=tu_token_aqui
ALLOWED_CHAT_IDS=123456789,987654321
# Varios proyectos: nombre=ruta separados por punto y coma
WORKSPACES=api=/ruta/al/api;app=/ruta/al/app

# Compatibilidad anterior para un solo proyecto; se ignora si WORKSPACES está configurado
WORKSPACE=/ruta/al/proyecto
CODEX_TIMEOUT=900
